# AuditLens — environment template. Copy to .env and fill in. NEVER commit .env.

# --- Google Cloud / Gemini (Vertex AI via ADC) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_GENAI_USE_VERTEXAI=true
# gemini-2.5-flash = fast/cheap (good for the multi-trace dashboard); gemini-2.5-pro = deeper rigor.
GEMINI_MODEL=gemini-2.5-flash

# --- Arize Phoenix (partner) ---
# Hosted spaces look like https://app.phoenix.arize.com/s/<your-space>
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/your-space
PHOENIX_API_KEY=phx-xxxxxxxxxxxxxxxx
# Must be a project that exists in your space (check GET /v1/projects).
PHOENIX_PROJECT=default


# --- Partner MCP at runtime ---
# true  → reads + the dataset write go through the Arize Phoenix MCP server
#         (@arizeai/phoenix-mcp), the same integration the judged Agent Builder agent
#         uses. This is the required-tech path; the app falls back to Phoenix REST on error.
# unset → Phoenix REST only (zero-dependency fallback).
USE_PHOENIX_MCP=true

# --- App ---
PORT=8080
NODE_ENV=development

# --- Demo mode: set MOCK=true to run the full UI + ApprovalBar flow with
# canned data and NO credentials (great for rehearsing the ~3-min demo). ---
# MOCK=true
