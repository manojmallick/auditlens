{
  "name": "auditlens-starter",
  "version": "1.0.0",
  "description": "AuditLens — EU AI Act trace compliance agent. Gemini 3 + Google Cloud Agent Builder + Arize Phoenix MCP.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch --env-file-if-exists=.env src/server.js",
