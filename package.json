    "score": "node --env-file-if-exists=.env scripts/score.js",
    "calibrate": "node --env-file-if-exists=.env scripts/calibrate.js",
    "seed": "python3 seed_demo.py"
  },
  "dependencies": {
    "@arizeai/phoenix-mcp": "^4.0.13",
    "@google/genai": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2"
  }
}
